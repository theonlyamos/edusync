# ============================================================
# InsyteAI - Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
# ============================================================

# ----------------------------------------------------------
# REQUIRED: Google Gemini API Key
# ----------------------------------------------------------
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ----------------------------------------------------------
# OPTIONAL: Vertex AI (Google Cloud)
# ----------------------------------------------------------
# If set, the app uses Vertex AI instead of the consumer API.
# You must also be authenticated via:
#   gcloud auth application-default login
#
# GEMINI_PROJECT_ID=your-gcp-project-id
# GEMINI_LOCATION=us-central1

# ----------------------------------------------------------
# OPTIONAL: Model Override
# ----------------------------------------------------------
# Override the default Gemini model (default: gemini-3.1-flash-lite-preview)
# GEMINI_MODEL=gemini-2.5-flash
