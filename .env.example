# ===========================================
# Supabase Configuration
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ===========================================
# OpenAI Configuration
# ===========================================
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# ===========================================
# Google Gemini Configuration
# ===========================================
GEMINI_API_KEY=
GEMINI_BASE_URL=
NEXT_PUBLIC_GEMINI_LIVE_MODEL=

# ===========================================
# Stripe Configuration
# ===========================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CREDIT_PRODUCT_ID=
STRIPE_CREDIT_PRICE_ID=

# ===========================================
# Tavily Search API (Optional)
# ===========================================
TAVILY_API_KEY=

# ===========================================
# Helicone Observability (Optional)
# ===========================================
HELICONE_BASE_URL=
HELICONE_API_KEY=

# ===========================================
# Application Settings
# ===========================================
NEXT_PUBLIC_BASE_URL=http://localhost:3000
AI_PROVIDER=GEMINI

# ===========================================
# Live classes (LiveKit + agent worker)
# ===========================================
LIVEKIT_URL=wss://your-project.livekit.cloud
NEXT_PUBLIC_LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# Registered LiveKit agent name (must match deployed workers). When set, the app dispatches that agent into live-class rooms on create (and via explicit dispatch if the room already exists).
LIVEKIT_AGENT_NAME=
# Optional; defaults to LIVEKIT_API_SECRET for WebhookReceiver
LIVEKIT_WEBHOOK_SECRET=
# Minutes before scheduled_start_at that join is allowed (default 15)
LIVE_CLASS_LOBBY_MINUTES=15
# Optional; match LIVE_CLASS_LOBBY_MINUTES so the Join button enables at the same time as the server (default 15)
NEXT_PUBLIC_LIVE_CLASS_LOBBY_MINUTES=15
# Shared secret for POST /api/live-classes/agent/persist-visualization (agent worker only)
LIVE_CLASS_AGENT_SECRET=
LIVEKIT_AGENT_NAME=
# Base URL the agent uses to call Next.js (e.g. https://app.example.com)
LIVE_CLASS_APP_BASE_URL=http://localhost:3000
# Agent: Google Gemini Live (see LiveKit Google plugin docs)
GOOGLE_API_KEY=
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
